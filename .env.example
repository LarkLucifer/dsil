# DSIL Configuration Template
# Copy this to .env and fill in the values

# AI Assistant
# Get your key from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
DSIL_OPENAI_MODEL=gpt-4-turbo

# Out-of-Band (OOB) Testing
# Get your token from https://app.interactsh.com/ (optional)
INTERACTSH_TOKEN=your_interactsh_token_here

# Scanning Configuration
DSIL_PROFILE=local
DSIL_SCAN_MODE=scan
DSIL_VERBOSITY=1

# Katana (Ensure katana is in your PATH)
KATANA_ENABLED=true
